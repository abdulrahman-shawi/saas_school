generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ACADEMY_ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BatchStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  FROZEN
}

enum SessionType {
  ONSITE
  ONLINE
  HYBRID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE_WALLET
  OTHER
}

enum StaffDepartment {
  FRONT_DESK
  ACCOUNTING
  OPERATIONS
  HR
  ACADEMIC_COORDINATION
  OTHER
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Academy {
  id          String              @id @default(uuid())
  code        String              @unique
  name        String              @unique
  legalName   String?
  logoUrl     String?
  phone       String?
  email       String?
  websiteUrl  String?
  address     String?
  city        String?
  country     String?
  timezone    String              @default("UTC")
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  branches    Branch[]
  users       User[]
  students    StudentProfile[]
  teachers    TeacherProfile[]
  parents     ParentProfile[]
  staff       StaffProfile[]
  courses     Course[]
  classroomSubjects ClassroomCourse[]
  batches     Batch[]
  sessions    Session[]
  enrollments Enrollment[]
  attendances Attendance[]
  invoices    Invoice[]
  payments    Payment[]
  links       ParentStudentLink[]
  classrooms  Classroom[]
  classroomLinks ClassroomTeacher[]
  timetableSlots TimetableSlot[]
  messages    Message[]
  auditLogs   AuditLog[]
}

model PlatformAdmin {
  id                 String     @id @default(uuid())
  username           String     @unique
  passwordHash       String
  fullName           String
  email              String?    @unique
  phone              String?
  isActive           Boolean    @default(true)
  mustChangePassword Boolean    @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  auditLogs          AuditLog[]
}

model Branch {
  id        String           @id @default(uuid())
  academyId String
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  academy   Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  students  StudentProfile[]
  teachers  TeacherProfile[]
  staff     StaffProfile[]
  batches   Batch[]
  sessions  Session[]

  @@unique([academyId, code])
  @@index([academyId, name])
}

model User {
  id                 String          @id @default(uuid())
  academyId          String
  username           String
  passwordHash       String
  fullName           String
  email              String?
  phone              String?
  role               UserRole
  status             UserStatus      @default(ACTIVE)
  mustChangePassword Boolean         @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  academy            Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  studentProfile     StudentProfile?
  teacherProfile     TeacherProfile?
  parentProfile      ParentProfile?
  staffProfile       StaffProfile?
  receivedPayments   Payment[]       @relation("PaymentReceiver")
  sentMessages       Message[]       @relation("MessageSender")
  receivedMessages   Message[]       @relation("MessageReceiver")
  auditLogs          AuditLog[]

  @@unique([academyId, username])
  @@unique([academyId, email])
  @@index([academyId, role, status])
}

model StudentProfile {
  id             String              @id @default(uuid())
  academyId      String
  userId         String              @unique
  branchId       String?
  classroomId    String?
  studentCode    String
  firstName      String?
  lastName       String?
  rollNumber     String?
  gender         Gender?
  dateOfBirth    DateTime?
  profilePicUrl  String?
  religion       String?
  caste          String?
  bloodGroup     String?
  height         String?
  weight         String?
  enrollmentDate DateTime            @default(now())
  accessActiveUntil DateTime?
  lastActivatedAt DateTime?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  academy        Academy             @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  classroom      Classroom?          @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  enrollments    Enrollment[]
  parentLinks    ParentStudentLink[]
  invoices       Invoice[]

  @@unique([academyId, studentCode])
  @@unique([academyId, rollNumber])
  @@index([academyId, branchId])
}

model TeacherProfile {
  id             String    @id @default(uuid())
  academyId      String
  userId         String    @unique
  branchId       String?
  teacherCode    String
  firstName      String?
  lastName       String?
  gender         Gender?
  dateOfBirth    DateTime?
  specialization String?
  maritalStatus  String?
  profilePicUrl  String?
  currentAddress String?
  permanentAddress String?
  qualification  String?
  workExperience String?
  note           String?
  hireDate       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  academy        Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batches        Batch[]
  sessions       Session[]
  classroomLinks ClassroomTeacher[]
  timetableSlots TimetableSlot[]

  @@unique([academyId, teacherCode])
  @@index([academyId, branchId])
}

model Classroom {
  id        String            @id @default(uuid())
  academyId String
  code      String
  name      String
  capacity  Int?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  academy   Academy           @relation(fields: [academyId], references: [id], onDelete: Cascade)
  teachers  ClassroomTeacher[]
  subjectLinks ClassroomCourse[]
  students  StudentProfile[]
  timetableSlots TimetableSlot[]

  @@unique([academyId, code])
  @@index([academyId, name])
}

model ClassroomCourse {
  id          String    @id @default(uuid())
  academyId   String
  classroomId String
  courseId    String
  createdAt   DateTime  @default(now())
  academy     Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([academyId, classroomId, courseId])
  @@index([academyId, courseId])
}

model ClassroomTeacher {
  id          String         @id @default(uuid())
  academyId   String
  classroomId String
  teacherId   String
  createdAt   DateTime       @default(now())
  academy     Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classroom   Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([academyId, classroomId, teacherId])
  @@index([academyId, teacherId])
}

model ParentProfile {
  id         String              @id @default(uuid())
  academyId  String
  userId     String              @unique
  firstName  String?
  lastName   String?
  gender     Gender?
  occupation String?
  address    String?
  profilePicUrl String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  academy    Academy             @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  links      ParentStudentLink[]

  @@index([academyId])
}

model StaffProfile {
  id            String          @id @default(uuid())
  academyId     String
  userId        String          @unique
  branchId      String?
  staffCode     String
  department    StaffDepartment @default(OTHER)
  positionTitle String?
  hireDate      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  academy       Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch        Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([academyId, staffCode])
  @@index([academyId, branchId])
}

model ParentStudentLink {
  id        String         @id @default(uuid())
  academyId String
  parentId  String
  studentId String
  relation  String
  isPrimary Boolean        @default(false)
  createdAt DateTime       @default(now())
  academy   Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  parent    ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([academyId, parentId, studentId])
  @@index([academyId, studentId])
}

model Course {
  id            String   @id @default(uuid())
  academyId     String
  code          String
  name          String
  description   String?
  durationHours Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  academy       Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  batches       Batch[]
  classroomLinks ClassroomCourse[]
  timetableSlots TimetableSlot[]

  @@unique([academyId, code])
  @@index([academyId, name])
}

model TimetableSlot {
  id          String         @id @default(uuid())
  academyId   String
  classroomId String
  courseId    String
  teacherId   String?
  dayOfWeek   Weekday
  startTime   String
  endTime     String
  roomLabel   String?
  notes       String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  academy     Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classroom   Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([academyId, classroomId, dayOfWeek])
  @@index([academyId, courseId, dayOfWeek])
}

model Batch {
  id           String          @id @default(uuid())
  academyId    String
  branchId     String?
  courseId     String
  instructorId String?
  code         String
  title        String?
  startDate    DateTime
  endDate      DateTime
  capacity     Int?
  status       BatchStatus     @default(PLANNED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  academy      Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  course       Course          @relation(fields: [courseId], references: [id], onDelete: Restrict)
  instructor   TeacherProfile? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  sessions     Session[]
  enrollments  Enrollment[]

  @@unique([academyId, code])
  @@index([academyId, courseId, status])
}

model Enrollment {
  id          String           @id @default(uuid())
  academyId   String
  studentId   String
  batchId     String
  enrolledAt  DateTime         @default(now())
  status      EnrollmentStatus @default(ACTIVE)
  finalScore  Float?
  academy     Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student     StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  batch       Batch            @relation(fields: [batchId], references: [id], onDelete: Restrict)
  attendances Attendance[]
  invoices    Invoice[]

  @@unique([academyId, studentId, batchId])
  @@index([academyId, batchId, status])
}

model Session {
  id           String          @id @default(uuid())
  academyId    String
  batchId      String
  branchId     String?
  instructorId String?
  title        String?
  sessionType  SessionType     @default(ONSITE)
  startsAt     DateTime
  endsAt       DateTime
  roomName     String?
  meetingUrl   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  academy      Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  batch        Batch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  instructor   TeacherProfile? @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  attendances  Attendance[]

  @@index([academyId, batchId, startsAt])
}

model Attendance {
  id           String           @id @default(uuid())
  academyId    String
  sessionId    String
  enrollmentId String
  status       AttendanceStatus @default(PRESENT)
  checkInAt    DateTime?
  notes        String?
  createdAt    DateTime         @default(now())
  academy      Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  session      Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([academyId, sessionId, enrollmentId])
  @@index([academyId, status])
}

model Invoice {
  id            String         @id @default(uuid())
  academyId     String
  enrollmentId  String?
  studentId     String
  invoiceNumber String
  status        InvoiceStatus  @default(ISSUED)
  issueDate     DateTime       @default(now())
  dueDate       DateTime
  currency      String         @default("USD")
  totalAmount   Decimal        @db.Decimal(10, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  academy       Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  enrollment    Enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Restrict)
  items         InvoiceItem[]
  payments      Payment[]

  @@unique([academyId, invoiceNumber])
  @@index([academyId, studentId, status])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  lineTotal   Decimal @db.Decimal(10, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id               String        @id @default(uuid())
  academyId        String
  invoiceId        String
  receivedByUserId String?
  paymentReference String?
  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod @default(CASH)
  paidAt           DateTime      @default(now())
  receiptUrl       String?
  notes            String?
  createdAt        DateTime      @default(now())
  academy          Academy       @relation(fields: [academyId], references: [id], onDelete: Cascade)
  invoice          Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receivedBy       User?         @relation("PaymentReceiver", fields: [receivedByUserId], references: [id], onDelete: SetNull)

  @@unique([academyId, paymentReference])
  @@index([academyId, paidAt])
}

model AuditLog {
  id                   String         @id @default(uuid())
  academyId            String?
  actorUserId          String?
  actorPlatformAdminId String?
  action               String
  entityType           String
  entityId             String?
  metadata             Json?
  createdAt            DateTime       @default(now())
  academy              Academy?       @relation(fields: [academyId], references: [id], onDelete: SetNull)
  actorUser            User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorPlatformAdmin   PlatformAdmin? @relation(fields: [actorPlatformAdminId], references: [id], onDelete: SetNull)

  @@index([academyId, createdAt])
  @@index([entityType, entityId])
}

model Message {
  id             String   @id @default(uuid())
  academyId      String
  senderUserId   String
  receiverUserId String
  subject        String?
  body           String
  readAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  academy        Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  sender         User     @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  receiver       User     @relation("MessageReceiver", fields: [receiverUserId], references: [id], onDelete: Cascade)

  @@index([academyId, createdAt])
  @@index([academyId, senderUserId])
  @@index([academyId, receiverUserId])
}
